name: ghorgsync
default_branch: main
config:
  description: "Clone and update all organization repositories in one folder, with clean-state and branch audits plus warnings for stray content."
  license: MIT
  language: go
  release: release-go
  justfile: true
  status: active
  release_github: true
  codecov:
    enabled: false
  docs:
    enabled: true
    domain: ghorgsync.unitvectorylabs.com
